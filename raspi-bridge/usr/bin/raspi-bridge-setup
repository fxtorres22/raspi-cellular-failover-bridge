#!/bin/bash
# raspi-bridge-setup — Interactive setup wizard for MAC-based interface pinning
# Auto-detects Ethernet interfaces and MACs from 'ip link show', lets the user
# confirm or override assignments, then writes udev rules.

set -e

RULES_FILE="/etc/udev/rules.d/70-persistent-net.rules"

# ─── Colors ──────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m' # No Color

echo -e "${BOLD}╔════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║     raspi-bridge Setup Wizard              ║${NC}"
echo -e "${BOLD}╚════════════════════════════════════════════╝${NC}"
echo ""

# ─── Check root ──────────────────────────────────────────────────────────────
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}ERROR: This script must be run as root (sudo raspi-bridge-setup)${NC}"
    exit 1
fi

# ─── Detect Ethernet interfaces ─────────────────────────────────────────────
echo -e "${CYAN}Detecting Ethernet interfaces...${NC}"
echo ""

# Build arrays of interface names and MACs
declare -a IFACE_NAMES=()
declare -a IFACE_MACS=()

while IFS= read -r line; do
    # Parse lines like: "2: eth0: <BROADCAST,..."
    if [[ "$line" =~ ^[0-9]+:\ ([^:]+): ]]; then
        current_iface="${BASH_REMATCH[1]}"
        # Trim whitespace
        current_iface=$(echo "$current_iface" | xargs)
    fi
    # Parse lines like: "    link/ether aa:bb:cc:dd:ee:ff brd ..."
    if [[ "$line" =~ link/ether\ ([0-9a-f:]+) ]]; then
        mac="${BASH_REMATCH[1]}"
        if [ -n "$current_iface" ]; then
            IFACE_NAMES+=("$current_iface")
            IFACE_MACS+=("$mac")
        fi
    fi
done < <(ip link show)

if [ ${#IFACE_NAMES[@]} -eq 0 ]; then
    echo -e "${RED}No Ethernet interfaces detected!${NC}"
    echo "Make sure your built-in Ethernet and USB modem are connected."
    exit 1
fi

# Display detected interfaces
echo -e "${BOLD}  #   Interface      MAC Address${NC}"
echo "  ─── ────────────── ─────────────────────"
for i in "${!IFACE_NAMES[@]}"; do
    printf "  %-3s %-14s %s\n" "$((i+1))" "${IFACE_NAMES[$i]}" "${IFACE_MACS[$i]}"
done
echo ""

# ─── Select LAN interface (eth0 — to router) ────────────────────────────────
echo -e "${YELLOW}── Step 1: Select the LAN interface (connects to your router)${NC}"
echo -e "   This will be pinned as ${BOLD}eth0${NC} with a static IP of 192.168.100.1"
echo ""

ETH0_MAC=""
while true; do
    read -p "  Enter the number of the LAN interface (or type a MAC manually): " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#IFACE_NAMES[@]} ]; then
        ETH0_MAC="${IFACE_MACS[$((choice-1))]}"
        echo -e "  Selected: ${GREEN}${IFACE_NAMES[$((choice-1))]} → ${ETH0_MAC}${NC}"
        break
    elif [[ "$choice" =~ ^[0-9a-fA-F:]+$ ]] && [ ${#choice} -eq 17 ]; then
        ETH0_MAC="$choice"
        echo -e "  Manual MAC: ${GREEN}${ETH0_MAC}${NC}"
        break
    else
        echo -e "  ${RED}Invalid choice. Enter a number (1-${#IFACE_NAMES[@]}) or a full MAC address.${NC}"
    fi
done
echo ""

# ─── Select WAN interface (eth1 — to LTE modem) ─────────────────────────────
echo -e "${YELLOW}── Step 2: Select the WAN interface (connects to your LTE modem)${NC}"
echo -e "   This will be pinned as ${BOLD}eth1${NC} with DHCP and MTU 1420"
echo ""

ETH1_MAC=""
while true; do
    read -p "  Enter the number of the WAN interface (or type a MAC manually): " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#IFACE_NAMES[@]} ]; then
        ETH1_MAC="${IFACE_MACS[$((choice-1))]}"
        if [ "$ETH1_MAC" == "$ETH0_MAC" ]; then
            echo -e "  ${RED}Cannot use the same interface for both LAN and WAN!${NC}"
            continue
        fi
        echo -e "  Selected: ${GREEN}${IFACE_NAMES[$((choice-1))]} → ${ETH1_MAC}${NC}"
        break
    elif [[ "$choice" =~ ^[0-9a-fA-F:]+$ ]] && [ ${#choice} -eq 17 ]; then
        ETH1_MAC="$choice"
        echo -e "  Manual MAC: ${GREEN}${ETH1_MAC}${NC}"
        break
    else
        echo -e "  ${RED}Invalid choice. Enter a number (1-${#IFACE_NAMES[@]}) or a full MAC address.${NC}"
    fi
done
echo ""

# ─── Summary & confirmation ─────────────────────────────────────────────────
echo -e "${BOLD}── Summary ──────────────────────────────────${NC}"
echo -e "  eth0 (LAN/Router):  ${GREEN}${ETH0_MAC}${NC}"
echo -e "  eth1 (WAN/LTE):     ${GREEN}${ETH1_MAC}${NC}"
echo ""

read -p "  Write these to ${RULES_FILE}? [Y/n] " confirm
if [[ "$confirm" =~ ^[Nn] ]]; then
    echo "  Aborted. No changes were made."
    exit 0
fi

# ─── Write udev rules ───────────────────────────────────────────────────────
cat > "$RULES_FILE" <<EOF
# raspi-bridge: MAC-based interface pinning
# Generated by raspi-bridge-setup on $(date '+%Y-%m-%d %H:%M:%S')
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="?*", ATTR{address}=="${ETH0_MAC}", NAME="eth0"
SUBSYSTEM=="net", ACTION=="add", DRIVERS=="?*", ATTR{address}=="${ETH1_MAC}", NAME="eth1"
EOF

echo ""
echo -e "${GREEN}  ✓ udev rules written to ${RULES_FILE}${NC}"

# ─── Reload udev ────────────────────────────────────────────────────────────
udevadm control --reload-rules 2>/dev/null || true
udevadm trigger 2>/dev/null || true
echo -e "${GREEN}  ✓ udev rules reloaded${NC}"

# ─── Optional: Disable Wi-Fi & Bluetooth ─────────────────────────────────────
echo ""
echo -e "${YELLOW}── Optional: Disable Wi-Fi & Bluetooth (power saving)${NC}"
read -p "  Disable onboard Wi-Fi and Bluetooth? [y/N] " disable_wireless

if [[ "$disable_wireless" =~ ^[Yy] ]]; then
    CONFIG_FILE="/boot/firmware/config.txt"
    if [ ! -f "$CONFIG_FILE" ]; then
        CONFIG_FILE="/boot/config.txt"
    fi

    if [ -f "$CONFIG_FILE" ]; then
        # Add overlays if not already present
        grep -q "dtoverlay=disable-wifi" "$CONFIG_FILE" || echo "dtoverlay=disable-wifi" >> "$CONFIG_FILE"
        grep -q "dtoverlay=disable-bt"   "$CONFIG_FILE" || echo "dtoverlay=disable-bt"   >> "$CONFIG_FILE"
        echo -e "${GREEN}  ✓ Wi-Fi and Bluetooth will be disabled on next reboot${NC}"
    else
        echo -e "${RED}  Could not find boot config file. Add these lines manually:${NC}"
        echo "    dtoverlay=disable-wifi"
        echo "    dtoverlay=disable-bt"
    fi
else
    echo "  Skipped."
fi

echo ""
echo -e "${BOLD}╔════════════════════════════════════════════╗${NC}"
echo -e "${BOLD}║  Setup complete! Reboot to apply changes.  ║${NC}"
echo -e "${BOLD}╚════════════════════════════════════════════╝${NC}"
echo ""

exit 0
